generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(255)
  logo               String?  @db.Text
  token              String   @unique @default(uuid()) @db.Uuid
  preferredLang      String   @default("en") @db.VarChar(10)
  preferredCurrency  String   @default("USD") @db.VarChar(10)
  createdAt          DateTime @default(now())
  campaigns          Campaign[]
}

model Campaign {
  id                  String     @id @default(uuid()) @db.Uuid
  clientId            String     @db.Uuid
  client              Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceType         String?    @db.VarChar(128)
  category            String?    @db.VarChar(128)
  status              String     @default("PENDING")
  totalClientPaid     Float      @default(0)
  actualPlatformSpend Float      @default(0)
  serviceFee          Float      @default(0)
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  adItems             AdItem[]
  logs                Log[]
}

model AdItem {
  id             String    @id @default(uuid()) @db.Uuid
  campaignId     String    @db.Uuid
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postUrl        String    @db.Text
  previewImage   String?   @db.Text
  itemBudget     Float     @default(0)
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
}

model Log {
  id         String   @id @default(uuid()) @db.Uuid
  campaignId String   @db.Uuid
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  action     String   @db.VarChar(255)
  user       String   @default("SYSTEM") @db.VarChar(64)
  details    String?  @db.Text
  createdAt  DateTime @default(now())
}

model Analytics {
  id         String   @id @default(uuid()) @db.Uuid
  ipHash     String   @db.VarChar(255)
  country    String?  @db.VarChar(255)
  city       String?  @db.VarChar(255)
  device     String?  @db.VarChar(64)
  os         String?  @db.VarChar(64)
  browser    String?  @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now())
}
